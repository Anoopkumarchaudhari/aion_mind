OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_ADVANCED_MODEL=
OPENAI_JUDGE_MODEL=gpt-5.5

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/aion_mind
DATABASE_SSL=false

# Alternative split PostgreSQL config. This avoids URL-encoding special password characters.
# If these values are complete, they are used before DATABASE_URL.
AION_PG_HOST=
AION_PG_PORT=5432
AION_PG_DATABASE=postgres
AION_PG_USER=
AION_PG_PASSWORD=
AION_PG_SSL=true

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
ANTHROPIC_OPUS_MODEL=

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro

GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_FALLBACK_MODELS=

GROK_API_KEY=
GROK_MODEL=

AION_DEBUG=false
AION_PROVIDER_TIMEOUT_MS=25000
AION_PROVIDER_MAX_RETRIES=2
AION_PROVIDER_RETRY_BASE_MS=1000
AION_PROVIDER_RETRY_MAX_MS=8000
AION_JUDGE_TIMEOUT_MS=30000
NEXT_PUBLIC_AION_DEBUG=false
